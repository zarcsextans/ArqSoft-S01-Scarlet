@model Catalogo.Models.Item

<style>
    body {
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        min-height: 100vh;
        color: white;
    }

    .detalle-card {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 25px;
        padding: 35px;
        box-shadow: 0 0 25px rgba(0,255,247,0.25);
        animation: aparecer 0.6s ease;
    }

    @@keyframes aparecer {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .titulo-game {
        font-size: 3rem;
        font-weight: bold;
        color: #00fff7;
        text-shadow: 0 0 15px #00fff7;
    }

    .info-label {
        color: #ff4df0;
        font-weight: bold;
        font-size: 1.1rem;
    }

    .descripcion-box {
        background: rgba(255,255,255,0.05);
        border-left: 4px solid #00fff7;
        padding: 15px;
        border-radius: 10px;
        color: #dcdcdc;
    }

    .btn-gamer {
        background: linear-gradient(45deg, #ff00cc, #3333ff);
        border: none;
        color: white;
        font-weight: bold;
        padding: 10px 20px;
        border-radius: 12px;
        transition: 0.3s;
        text-decoration: none;
    }

        .btn-gamer:hover {
            transform: scale(1.05);
            box-shadow: 0 0 20px #ff00cc;
            color: white;
        }

    .badge-gamer {
        background: #00fff7;
        color: black;
        font-weight: bold;
        padding: 8px 14px;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 20px;
    }
</style>

<div class="container mt-5">

    <div class="detalle-card">

        <h1 class="titulo-game">
            🎮 @Model.Titulo
        </h1>

        <span class="badge-gamer">
            @Model.Genero
        </span>

        <div class="mb-3">
            <span class="info-label">🕹 Consola:</span>
            <span>@Model.Consola</span>
        </div>

        <div class="mb-4">
            <span class="info-label">📅 Año:</span>
            <span>@Model.Ano</span>
        </div>

        <div class="descripcion-box">
            <span class="info-label">📖 Descripción</span>
            <p class="mt-2">
                @Model.Descripcion
            </p>
        </div>

        <div class="mt-4">
            <a asp-action="Index" class="btn-gamer">
                ⬅ Volver al Catálogo
            </a>
        </div>

    </div>

</div>