@model List<Catalogo.Models.Item>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">🎮 Mi Catálogo de Videojuegos</h1>
        <a asp-action="Agregar" class="btn btn-primary shadow-sm">+ Nuevo Videojuego</a>
    </div>

    <div class="mb-4">
        <div class="btn-group flex-wrap shadow-sm" role="group">
            <a asp-action="Index" class="btn btn-outline-secondary @(string.IsNullOrEmpty(Context.Request.Query["genero"]) ? "active" : "")">Todos</a>
            @foreach (var gen in ViewBag.Generos as List<string>)
            {
                <a asp-action="Index" asp-route-genero="@gen"
                   class="btn btn-outline-secondary @(Context.Request.Query["genero"] == gen ? "active" : "")">@gen</a>
            }
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@item.Titulo</h5>
                        <h6 class="card-subtitle mb-2 text-muted small">@item.Genero • @item.Ano</h6>
                        <p class="card-text text-truncate">Descripción breve o detalles adicionales...</p>
                    </div>
                    <div class="card-footer bg-transparent border-0">
                        <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary w-100">Ver Detalles</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>