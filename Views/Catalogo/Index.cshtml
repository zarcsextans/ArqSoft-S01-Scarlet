@model List<Catalogo.Models.Item>

<style>
    body {
        background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        min-height: 100vh;
        color: white;
    }

    .titulo-gamer {
        font-weight: bold;
        color: #00fff7;
        text-shadow: 0 0 10px #00fff7;
    }

    .card-gamer {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .card-gamer:hover {
        transform: translateY(-8px) scale(1.03);
        box-shadow: 0 0 25px #00fff7;
    }

    .card-title {
        color: #ff4df0;
        font-weight: bold;
    }

    .btn-gamer {
        background: linear-gradient(45deg, #ff00cc, #3333ff);
        border: none;
        color: white;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-gamer:hover {
        transform: scale(1.05);
        box-shadow: 0 0 15px #ff00cc;
    }

    .filtro-btn {
        border-radius: 20px;
        margin: 4px;
    }

    .texto-desc {
        color: #d1d1d1;
    }

    .badge-gamer {
        background: #00fff7;
        color: black;
        font-weight: bold;
    }
</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4 titulo-gamer">
            🎮 GamerVerse
        </h1>

        <a asp-action="Agregar" class="btn btn-gamer shadow">
            + Nuevo Videojuego
        </a>
    </div>

    <!-- FILTROS -->
    <div class="mb-4">
        <div class="d-flex flex-wrap">

            <a asp-action="Index"
                   class="btn btn-outline-info filtro-btn">
                Todos
            </a>

            @foreach (var gen in ViewBag.Generos as List<string>)
            {
                <a asp-action="Index"
                       asp-route-genero="@gen"
                       class="btn btn-outline-light filtro-btn">
                    @gen
                </a>
            }

        </div>
    </div>

    <!-- CARDS -->
    <div class="row row-cols-1 row-cols-md-3 g-4">

        @foreach (var item in Model)
        {
            <div class="col">

                <div class="card card-gamer h-100">

                    <div class="card-body">

                        <h4 class="card-title">
                            @item.Titulo
                        </h4>

                        <span class="badge badge-gamer mb-2">
                            @item.Genero
                        </span>

                        <p class="small text-info">
                            🎮 @item.Consola
                        </p>

                        <p class="small text-warning">
                            📅 @item.Ano
                        </p>

                        <p class="texto-desc">
                            @(item.Descripcion.Length > 100
                                ? item.Descripcion.Substring(0, 100) + "..."
                                : item.Descripcion)
                        </p>

                    </div>

                    <div class="card-footer bg-transparent border-0">

                        <a asp-action="Detalle"
                               asp-route-id="@item.Id"
                               class="btn btn-gamer w-100">
                            Ver Detalles
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>