@model List<Catalogo.Models.Item>

@{
    var generos = ViewBag.Generos as List<string> ?? new List<string>();
}

<style>
    body {
        background: radial-gradient(circle at top left, #1b0033, transparent 30%), radial-gradient(circle at bottom right, #001f3f, transparent 30%), linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        min-height: 100vh;
        color: white;
        overflow-x: hidden;
    }

    .titulo-gamer {
        font-weight: bold;
        color: #00fff7;
        text-shadow: 0 0 15px #00fff7;
    }

    .card-gamer {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        backdrop-filter: blur(12px);
        border-radius: 22px;
        transition: all 0.35s ease;
        overflow: hidden;
        position: relative;
    }

        .card-gamer::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient( 120deg, transparent, rgba(255,255,255,0.08), transparent );
            transform: translateX(-100%);
            transition: 0.6s;
        }

        .card-gamer:hover::before {
            transform: translateX(100%);
        }

        .card-gamer:hover {
            transform: translateY(-10px) scale(1.03);
            box-shadow: 0 0 20px #00fff7, 0 0 40px rgba(0,255,247,0.4);
        }

    .card-title {
        color: #ff4df0;
        font-weight: bold;
    }

    .btn-gamer {
        background: linear-gradient(45deg, #ff00cc, #3333ff);
        border: none;
        color: white;
        font-weight: bold;
        border-radius: 12px;
        transition: 0.3s;
    }

        .btn-gamer:hover {
            transform: scale(1.05);
            box-shadow: 0 0 18px #ff00cc;
            color: white;
        }

    .filtro-btn {
        border-radius: 20px;
        margin: 4px;
        transition: 0.3s;
    }

        .filtro-btn:hover {
            transform: translateY(-2px);
        }

    .texto-desc {
        color: #d1d1d1;
    }

    .badge-gamer {
        background: #00fff7;
        color: black;
        font-weight: bold;
        border-radius: 12px;
        padding: 8px 12px;
    }

    .buscador {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        border-radius: 15px;
        padding: 12px;
    }

        .buscador:focus {
            background: rgba(255,255,255,0.12);
            color: white;
            border-color: #00fff7;
            box-shadow: 0 0 15px #00fff7;
        }

        .buscador::placeholder {
            color: #cfcfcf;
        }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h1 class="display-4 titulo-gamer">
            🎮 GamerVerse
        </h1>

        <a asp-action="Agregar"
               class="btn btn-gamer shadow px-4 py-2">
            + Nuevo Videojuego
        </a>

    </div>

    <!-- BUSCADOR -->
    <div class="mb-4">

        <input type="text"
               id="buscador"
               class="form-control buscador"
               placeholder="🔍 Buscar videojuego..." />

    </div>

    <!-- FILTROS -->
    <div class="mb-4">

        <div class="d-flex flex-wrap">

            <a asp-action="Index"
                   class="btn btn-outline-info filtro-btn">
                Todos
            </a>

            @foreach (var gen in generos)
            {
                <a asp-action="Index"
                       asp-route-genero="@gen"
                       class="btn btn-outline-light filtro-btn">
                    @gen
                </a>
            }

        </div>

    </div>

    <!-- CARDS -->
    <div class="row row-cols-1 row-cols-md-3 g-4" id="contenedor-juegos">

        @foreach (var item in Model)
        {
            <div class="col juego-card">

                <div class="card card-gamer h-100">

                    <div class="card-body">

                        <h4 class="card-title">
                            @item.Titulo
                        </h4>

                        <span class="badge badge-gamer mb-2">
                            @item.Genero
                        </span>

                        <p class="small text-info">
                            🎮 @item.Consola
                        </p>

                        <p class="small text-warning">
                            📅 @item.Ano
                        </p>

                        <p class="texto-desc">
                            @(item.Descripcion.Length > 100
                                ? item.Descripcion.Substring(0, 100) + "..."
                                : item.Descripcion)
                        </p>

                    </div>

                    <div class="card-footer bg-transparent border-0">

                        <a asp-action="Detalle"
                               asp-route-id="@item.Id"
                               class="btn btn-gamer w-100">
                            Ver Detalles
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<script>

    const buscador = document.getElementById("buscador");

    buscador.addEventListener("keyup", function () {

        const filtro = buscador.value.toLowerCase();

        const tarjetas = document.querySelectorAll(".juego-card");

        tarjetas.forEach(card => {

            const texto = card.innerText.toLowerCase();

            if (texto.includes(filtro)) {
                card.style.display = "block";
            }
            else {
                card.style.display = "none";
            }

        });

    });

</script>